{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "src",
  "projects": {
    "dev": {
      "root": "",
      "sourceRoot": "src",
      "projectType": "application",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "dist/dev"
            },
            "index": "src/dev/src/index.html",
            "polyfills": ["src/dev/src/polyfills.ts"],
            "tsConfig": "src/dev/tsconfig.dev.json",
            "assets": [
              {
                "glob": "favicon.ico",
                "input": "src/dev/src",
                "output": "/"
              },
              {
                "glob": "**/*",
                "input": "src/dev/src/assets",
                "output": "/assets"
              }
            ],
            "styles": ["node_modules/@clr/ui/clr-ui.min.css", "dist/clr-addons/styles/clr-addons-phs.css"],
            "scripts": [
              "node_modules/@webcomponents/webcomponentsjs/custom-elements-es5-adapter.js",
              "node_modules/@webcomponents/webcomponentsjs/webcomponents-bundle.js"
            ],
            "extractLicenses": false,
            "sourceMap": true,
            "optimization": false,
            "namedChunks": true,
            "browser": "src/dev/src/main.ts"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/dev/src/environments/environment.ts",
                  "with": "src/dev/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true
            }
          },
          "defaultConfiguration": ""
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "dev:build"
          },
          "configurations": {
            "production": {
              "buildTarget": "dev:build:production"
            }
          }
        }
      }
    },
    "clr-addons": {
      "root": "src/clr-addons",
      "sourceRoot": "src/clr-addons",
      "projectType": "library",
      "prefix": "clr",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "src/clr-addons/ng-package.json"
          },
          "configurations": {
            "dev": {
              "tsConfig": "src/clr-addons/tsconfig.lib.json"
            },
            "production": {
              "tsConfig": "src/clr-addons/tsconfig.lib.prod.json"
            }
          }
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "main": "tests/tests.entry.ts",
            "tsConfig": "tsconfig.spec.json",
            "karmaConfig": "karma.conf.js",
            "polyfills": ["zone.js", "zone.js/testing"],
            "styles": ["node_modules/@clr/ui/clr-ui.min.css", "dist/clr-addons/styles/clr-addons-phs.css"]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["src/**/*.ts", "src/**/*.html"]
          }
        }
      }
    }
  },
  "schematics": {
    "@schematics/angular:component": {
      "style": "css",
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  },
  "cli": {
    "analytics": false
  }
}
