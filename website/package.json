  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --ssl",
    "start:dev": "ng serve --port 4300 --ssl",
    "build": "ng build",
    "deploy:ci": "npm run update:versions && ng build --configuration production --output-path=./dist/deploy && npm run generate:404",
    "generate:404": "cp-cli ./dist/deploy/index.html ./dist/deploy/404.html",
    "update:versions": "node ./replace-versions.js",
    "env": "env"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "22.0.8",
    "@angular/cdk": "22.0.6",
    "@angular/common": "22.0.8",
    "@angular/compiler": "22.0.8",
    "@angular/core": "22.0.8",
    "@angular/forms": "22.0.8",
    "@angular/platform-browser": "22.0.8",
    "@angular/platform-browser-dynamic": "22.0.8",
    "@angular/platform-server": "22.0.8",
    "@angular/router": "22.0.8",
    "@clr/angular": "^18.0.0",
    "@clr/ui": "^18.0.0",
    "@kolkov/angular-editor": "3.1.0",
    "@porscheinformatik/clr-addons": "file:../dist/clr-addons",
    "@webcomponents/custom-elements": "1.6.0",
    "@webcomponents/webcomponentsjs": "2.8.0",
    "angular-calendar": "0.32.2",
    "core-js": "3.49.0",
