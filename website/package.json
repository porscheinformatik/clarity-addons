    "@angular/compiler-cli": "22.0.8",
    "@angular/language-service": "22.0.8",
    "@types/node": "24.13.3",
    "cp-cli": "2.0.0",
    "gh-pages": "6.3.0",
    "ts-loader": "9.6.2",
    "typescript": "5.9.3"
  }
